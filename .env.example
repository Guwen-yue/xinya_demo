# 心芽守护 Demo 环境变量示例
# 复制为 .env 并填入真实值；部署时也可直接用真实环境变量覆盖

# ---- Qwen 树洞对话（SiliconFlow）----
SILICONFLOW_API_KEY=sk-your-api-key-here
TREEHOLE_MODEL=Qwen/Qwen2.5-7B-Instruct
MODEL_API_BASE=https://api.siliconflow.cn/v1

# ---- 百度语音识别（短语音 REST）----
# 在 https://console.baidubce.com/ai/#/ai/speech 创建应用，获取以下三组凭证
# Secret Key 只在服务端使用，不会下发到浏览器
BAIDU_ASR_API_KEY=your-baidu-api-key
BAIDU_ASR_SECRET_KEY=your-baidu-secret-key

# ---- 服务端口 ----
PORT=5173

# ---- 部署环境标志 ----
# 部署时设置为 production，启用以下安全措施：
# 1. 错误信息脱敏（不返回上游 API 的 detail）
# 2. 严格来源验证（仅允许同源请求，不允许 localhost）
# 开发环境留空或不设置即可
# NODE_ENV=production
